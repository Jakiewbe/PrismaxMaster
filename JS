            if (confirm("贾维斯：确认要重置今日计数协议吗？")) {
                this.setCount(0);
                this.resetAnomaly();
                localStorage.removeItem(MORNING_DONE_KEY);
                localStorage.removeItem(STORAGE_KEYS.MORNING_TARGET);
                location.reload();
            }
        },
        getMorningTarget() {
            const storedDate = localStorage.getItem(STORAGE_KEYS.DATE);
            if (storedDate !== getTodayStr()) return 0;
            return parseInt(localStorage.getItem(STORAGE_KEYS.MORNING_TARGET) || '0', 10);
        },
        setMorningTarget(ts) {
            localStorage.setItem(STORAGE_KEYS.DATE, getTodayStr());
            localStorage.setItem(STORAGE_KEYS.MORNING_TARGET, String(ts));
        },
        getAnomalyCount() {
            const currentToday = getTodayStr();
            const storedDate = localStorage.getItem(STORAGE_KEYS.DATE);
            if (storedDate !== currentToday) return 0;
            return parseInt(localStorage.getItem(STORAGE_KEYS.ANOMALY_COUNT) || '0', 10);
        },
        addAnomaly() {
            const current = this.getAnomalyCount();
            localStorage.setItem(STORAGE_KEYS.DATE, getTodayStr());
            localStorage.setItem(STORAGE_KEYS.ANOMALY_COUNT, String(current + 1));
        },
        resetAnomaly() {
            localStorage.setItem(STORAGE_KEYS.ANOMALY_COUNT, '0');
        },
        // 🆕 评论任务存储方法
        getCommentTarget() {
            const storedDate = localStorage.getItem(STORAGE_KEYS.DATE);
            if (storedDate !== getTodayStr()) return 0;
            return parseInt(localStorage.getItem(STORAGE_KEYS.COMMENT_TASK_TARGET) || '0', 10);
        },
        setCommentTarget(ts) {
            localStorage.setItem(STORAGE_KEYS.DATE, getTodayStr());
            localStorage.setItem(STORAGE_KEYS.COMMENT_TASK_TARGET, String(ts));
        },
        isCommentTaskDone() {
            return localStorage.getItem(STORAGE_KEYS.COMMENT_TASK_DONE) === getTodayStr();
        },
        markCommentTaskDone() {
            localStorage.setItem(STORAGE_KEYS.COMMENT_TASK_DONE, getTodayStr());
        },
        isCommentInProgress() {
            return localStorage.getItem(STORAGE_KEYS.COMMENT_IN_PROGRESS) === 'true';
        },
        setCommentInProgress(v) {
            localStorage.setItem(STORAGE_KEYS.COMMENT_IN_PROGRESS, v ? 'true' : 'false');
            // 🆕 同时记录/清除开始时间
            if (v) {
                localStorage.setItem(STORAGE_KEYS.COMMENT_TASK_START_TIME, String(Date.now()));
            } else {
                localStorage.removeItem(STORAGE_KEYS.COMMENT_TASK_START_TIME);
            }
        },
        // 🆕 获取评论任务开始时间
        getCommentTaskStartTime() {
            const ts = localStorage.getItem(STORAGE_KEYS.COMMENT_TASK_START_TIME);
            return ts ? parseInt(ts, 10) : 0;
        },
        // 🆕 检查评论任务是否超时（默认5分钟）
        isCommentTaskTimeout(timeoutMs = 5 * 60 * 1000) {
            if (!this.isCommentInProgress()) return false;
            const startTime = this.getCommentTaskStartTime();
            if (!startTime) return true;  // 没有开始时间但标记为进行中，视为异常
            return (Date.now() - startTime) > timeoutMs;
        },
        // 🆕 强制重置评论任务状态（用于超时恢复）
        resetCommentTaskState() {
            console.log('[评论任务] 🔄 强制重置任务状态');
            localStorage.removeItem(STORAGE_KEYS.COMMENT_IN_PROGRESS);
            localStorage.removeItem(STORAGE_KEYS.COMMENT_TASK_START_TIME);
        },
