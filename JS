    function getElementByXPath(xpath) {
        try {
            return document.evaluate(xpath, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
        } catch (e) {
            console.error('[Stark HUD] XPath 解析失败:', xpath, e);
            return null;
        }
    }

    function clickXPath(xpath, label) {
        const el = getElementByXPath(xpath);
        if (!el || !isVisibleElement(el)) {
            console.log(`[Stark HUD] 未找到或不可见: ${label}`);
            return false;
        }
        try {
            el.click();
            console.log(`[Stark HUD] 已点击: ${label}`);
            updateWatchdogHeartbeat();
            return true;
        } catch (e) {
            console.error(`[Stark HUD] 点击失败: ${label}`, e);
            return false;
        }
    }

    function findButtonNearElement(root, keywords) {
        if (!root) return null;
        const lowerKeywords = keywords.map(k => k.toLowerCase());
        const candidates = Array.from(root.querySelectorAll('button, div[role="button"], span'));
        return candidates.find(el => {
            if (!isVisibleElement(el)) return false;
            const text = (el.innerText || el.textContent || '').trim().toLowerCase();
            return lowerKeywords.some(k => text.includes(k));
        });
    }

    function clickElement(el, label) {
        if (!el || !isVisibleElement(el)) {
            console.log(`[Stark HUD] 未找到或不可见: ${label}`);
            return false;
        }
        try {
            el.scrollIntoView({ block: 'center', inline: 'center' });
        } catch (e) {}
        try {
            el.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
            el.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));
            el.click();
            console.log(`[Stark HUD] 已点击: ${label}`);
            updateWatchdogHeartbeat();
            return true;
        } catch (e) {
            console.error(`[Stark HUD] 点击失败: ${label}`, e);
            return false;
        }
    }

    function findArmElement(label, xpath) {
        const xpathEl = getElementByXPath(xpath);
        if (xpathEl && isVisibleElement(xpathEl)) return xpathEl;

        const candidates = Array.from(document.querySelectorAll('button, div[role="button"], div, li'));
        const pattern = new RegExp(`\\b${label.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\b`, 'i');
        const titleEl = candidates.find(el => {
            if (!isVisibleElement(el)) return false;
            const text = (el.innerText || el.textContent || '').trim();
            return pattern.test(text);
        });
        if (!titleEl) return null;

        return titleEl.closest('button, div[role="button"], li, [class*="Card"], [class*="card"]') || titleEl;
    }

    function joinArm(label, xpath, attempt = 0, done = () => {}) {
        const armEl = findArmElement(label, xpath);
        if (!armEl) {
            if (attempt < 20) {
                if (attempt === 0) console.log(`[Stark HUD] 等待 ${label} 卡片加载...`);
                setTimeout(() => joinArm(label, xpath, attempt + 1, done), 500);
            } else {
                console.log(`[Stark HUD] 等待 ${label} 超时，未切换`);
                done(false);
            }
            return;
        }

        const clickedArm = clickElement(armEl, `${label} 卡片`);
        if (!clickedArm) {
            done(false);
            return;
        }

        setTimeout(() => {
            const cardRoot = armEl.closest('div') || armEl;
            const localEnter = findButtonNearElement(cardRoot, CONFIG.text.enter);
            if (localEnter) {
                done(clickElement(localEnter, `${label} 卡片内入队按钮`));
                return;
            }

            const globalEnter = findBtn(CONFIG.text.enter);
            if (globalEnter) {
                done(clickElement(globalEnter, '全局入队按钮'));
                return;
            }

            console.log(`[Stark HUD] 未找到入队按钮，二次点击 ${label} 卡片尝试入队`);
            done(clickElement(armEl, `${label} 卡片（二次）`));
        }, 600);
    }

    function joinArenaArm(attempt = 0, done = () => {}) {
        joinArm('Arena Arm', CONFIG.armSwitchTask.arenaArmXPath, attempt, done);
    }

    function joinTrainingGoldArm(attempt = 0, done = () => {}) {
        joinArm('Training Arm Gold', CONFIG.armSwitchTask.trainingGoldArmXPath, attempt, done);
    }

    function waitConfirmThenEnter(attempt = 0) {
        if (confirmLeaveQueueIfPresent()) {
            setTimeout(() => waitUntilQueueLeft(() => clickEnterAfterLeave()), 500);
            return;
        }
        if (attempt >= 10) {
            console.log('[Stark HUD] 未检测到离队确认弹窗，尝试直接重新进入');
            waitUntilQueueLeft(() => clickEnterAfterLeave());
            return;
        }
        setTimeout(() => waitConfirmThenEnter(attempt + 1), 250);
    }

    function leaveQueueThenReenter(queueBtn) {
        try {
            queueBtn.click();
        } catch (e) {
            console.error('[Stark HUD] 点击离队按钮失败:', e);
        }

        setTimeout(() => waitConfirmThenEnter(0), 250);
    }

    function waitLeaveConfirmThenSwitchArena(attempt = 0) {
        if (confirmLeaveQueueIfPresent() || attempt >= 10) {
            const cfg = CONFIG.armSwitchTask;
            waitUntilQueueLeft((leftOk) => {
                if (!leftOk) {
                    Storage.setArmSwitchInProgress(false);
                    state.armSwitchInProgress = false;
                    updateUI('未能退出 Gold 队列，Arena 切换中止', '--', '--', '#ff3333');
                    return;
                }
                const avatarClicked = clickXPath(cfg.robotAvatarXPath, '左侧机器人头像');
                setTimeout(() => {
                    joinArenaArm(0, (arenaClicked) => {
                        if (arenaClicked) {
                            Storage.markArmSwitchDone();
                            updateUI('已切换到 Arena Arm', '--', '--', '#00ff99');
                        } else {
                            Storage.setArmSwitchInProgress(false);
                            updateUI('Arena Arm 切换失败，等待重试', '--', '--', '#ff3333');
                        }
                        state.armSwitchInProgress = false;
                        console.log(`[Stark HUD] Arena Arm 切换完成 avatar=${avatarClicked} arena=${arenaClicked}`);
                    });
                }, cfg.afterAvatarDelay);
            });
            return;
        }
        setTimeout(() => waitLeaveConfirmThenSwitchArena(attempt + 1), 250);
    }

    function switchToArenaArm(queueBtn) {
        if (state.armSwitchInProgress || Storage.isArmSwitchInProgress()) return;
        state.armSwitchInProgress = true;
        Storage.setArmSwitchInProgress(true);
        updateUI('训练金臂已完成 6 次，切换 Arena Arm...', '--', '--', '#66ccff');
        console.log('[Stark HUD] 开始切换到 Arena Arm');

        if (queueBtn) {
            try {
                queueBtn.click();
            } catch (e) {
                console.error('[Stark HUD] 点击离队按钮失败:', e);
            }
            setTimeout(() => waitLeaveConfirmThenSwitchArena(0), 250);
        } else {
            waitLeaveConfirmThenSwitchArena(10);
        }
    }

    function maybeSwitchToArenaArm(queueBtn) {
        const cfg = CONFIG.armSwitchTask;
        if (!cfg.enabled) return false;
        if (Storage.isArmSwitchDone() || Storage.isArmSwitchInProgress() || state.armSwitchInProgress) return false;
        if (Storage.get() < cfg.successThreshold) return false;
        switchToArenaArm(queueBtn);
        return true;
    }

    function returnToTrainingGold(queueBtn) {
        const cfg = CONFIG.armSwitchTask;
        updateUI('早八: 正在切回 Training Arm Gold...', '--', '--', '#66ccff');
        const switchGold = () => {
            const avatarClicked = clickXPath(cfg.robotAvatarXPath, '左侧机器人头像');
            setTimeout(() => {
                joinTrainingGoldArm(0, (goldClicked) => {
                    if (goldClicked) {
                        Storage.setCount(0);
                        Storage.resetAnomaly();
                        localStorage.removeItem(STORAGE_KEYS.ARM_SWITCH_DONE);
                        Storage.setArmSwitchInProgress(false);
                        state.armSwitchInProgress = false;
                        state.morningRequeueActive = true;
                        const c = document.getElementById('p-count');
                        if (c) c.innerText = "0";
                        updateAnomalyUI();
                        updateUI('早八: 已切回 Training Arm Gold', '--', '--', '#00ff99');
                    } else {
                        Storage.setArmSwitchInProgress(false);
                        state.armSwitchInProgress = false;
                        updateUI('早八: 切回 Gold 失败，等待重试', '--', '--', '#ff3333');
                    }
                    console.log(`[Stark HUD] Gold 切换完成 avatar=${avatarClicked} gold=${goldClicked}`);
                });
            }, cfg.afterAvatarDelay);
        };

        if (queueBtn) {
            state.armSwitchInProgress = true;
            Storage.setArmSwitchInProgress(true);
            try {
                queueBtn.click();
            } catch (e) {
                console.error('[Stark HUD] 点击离队按钮失败:', e);
            }
            setTimeout(() => confirmLeaveAndWait((leftOk) => {
                if (!leftOk) {
                    Storage.setArmSwitchInProgress(false);
                    state.armSwitchInProgress = false;
                    updateUI('早八: 未能退出当前队列', '--', '--', '#ff3333');
                    return;
                }
                switchGold();
            }), 250);
        } else {
            switchGold();
        }
    }

    const state = {
        isOp: false,
        sessStart: 0,
        qStart: 0,
        lastRawRank: -1,
        rankWorseStreak: 0,
        blindCount: 0,
        lastMoveTime: Date.now(),
        currentStuckLimit: 0,
        lastTimerStr: null,
        lastTimerChangeTime: 0,
        clickRetryCount: 0,
        requeueUsed: false,
        morningRequeueActive: false,
        morningTriggeredAt: 0,
        morningExtraRequeueDone: false,
        armSwitchInProgress: false,
        standbyMode: false,
        highRankLastHeavyScan: 0,
        highRankLastUiUpdate: 0,
        lastLoopDelay: 1000
    };

    function scheduleLoop(delay) {
        state.lastLoopDelay = delay;
        setTimeout(loop, delay);
    }

    function updateMorningInfo() {
        const info = document.getElementById('p-morning-info');
        if (!info) return;
        if (!CONFIG.morningEnabled) { info.style.display = 'none'; return; }
        const win = getMorningWindowMs();
        if (!win) { info.style.display = 'none'; return; }

        info.style.display = '';
        const now = Date.now();
        const { startMs, endMs } = win;

        if (hasMorningDoneToday() || state.morningTriggeredAt) {
            info.innerHTML = "✓ 早八协议已完成";
            return;
        }
        if (now > endMs) {
            info.innerHTML = "今日早八窗口已结束";
            return;
        }

        const targetMs = Storage.getMorningTarget();
        if (CONFIG.morningRandomInsideWindow) {
            if (!targetMs) {
                if (now < startMs) {
                    const timeStr = new Date(startMs).toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'});
                    info.innerHTML = `早八窗口 ${timeStr} 开启`;
                } else {
                    info.innerHTML = "正在生成触发时间点...";
                }
            } else {
                if (now < startMs) {
                    const timeStr = new Date(targetMs).toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'});
                    info.innerHTML = `⏰ 早八目标: ${timeStr}`;
                } else if (now >= startMs && now <= endMs) {
                    if (now < targetMs) {
                        const countdown = formatDurationMs(targetMs - now);
                        const timeStr = new Date(targetMs).toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'});
                        info.innerHTML = `⏳ 倒计时 ${countdown} (目标 ${timeStr})`;
                    } else {
                        info.innerHTML = "⚡ 正在触发早八协议...";
                    }
                }
            }
        } else {
            if (now < startMs) {
                const countdown = formatDurationMs(startMs - now);
                info.innerHTML = `⏳ 早八倒计时: ${countdown}`;
            } else {
                info.innerHTML = "⚡ 正在触发早八协议...";
            }
        }
    }

    function performMorningRequeue() {
        if (morningLock) return;
        morningLock = true;
        setTimeout(() => { morningLock = false; }, 1000);

        console.log("[Stark HUD] 执行早八协议检查...");
        updateWatchdogHeartbeat();

        if (scriptPaused) {
            console.log("[Stark HUD] 早八被跳过（脚本暂停）");
            return;
        }

        const queueBtn = findBtn(CONFIG.text.queuing);
        const enterBtn = findBtn(CONFIG.text.enter);

        if (!queueBtn && !enterBtn) {
            console.log("[Stark HUD] 早八触发时刻，但未检测到按钮！等待下一秒重试...");
            updateUI("早八: 按钮未刷新，等待中...", "--", "--", "#ff3333");
            return;
        }

        console.log("[Stark HUD] 发现按钮，触发点击！重置计数！");
        PrismaXNotifier.notifyMorningTrigger();

        Storage.setCount(0);
        Storage.resetAnomaly();
        const c = document.getElementById('p-count');
        if (c) c.innerText = "0";
        updateAnomalyUI();

        state.morningTriggeredAt = Date.now();
        markMorningDoneToday();
        state.morningRequeueActive = true;
        state.morningExtraRequeueDone = false;

        if (queueBtn) {
            if (CONFIG.armSwitchTask.morningReturnToGold) {
                returnToTrainingGold(queueBtn);
                return;
            }
            updateUI("早八: 正在重置连接...", "--", "--", "#66ccff");
            leaveQueueThenReenter(queueBtn);
            state.qStart = 0; state.lastRawRank = -1;
        } else if (enterBtn) {
            updateUI("早八: 建立新连接...", "--", "--", "#66ccff");
            try { enterBtn.click(); } catch (e) { console.error(e); }
            updateWatchdogHeartbeat();
        }
    }

    function loopUnsafe() {
        if (!document.body) { setTimeout(loop, 1000); return; }
        window.__PRISMAX_LOOP_HEARTBEAT_AT = Date.now();
        createPanel();

        const now = Date.now();
        updateWatchdogHeartbeat();

        const currentDay = getTodayStr();
        if (currentDay !== START_DAY) { safeReload("跨天自动刷新"); return; }

        const win = getMorningWindowMs();

        if (win) {
            const { startMs, endMs } = win;
            inMorningWindow = now >= startMs && now <= endMs;
            if (inMorningWindow) {
                startMorningWatchdog();
            } else {
                stopMorningWatchdog();
                inMorningWindow = false;
            }
        }

        if (win && !hasMorningDoneToday() && !hasMorningPreReloadToday()) {
            const { startMs } = win;
            if (now >= startMs - 60000 && now < startMs) {
                console.log("[Stark HUD] 触发早八前预刷新");
                markMorningPreReloadToday();
                safeReload("早八前预刷新");
                return;
            }
        }

        if (win && !hasMorningDoneToday() && !state.morningTriggeredAt) {
            const { startMs, endMs } = win;
            if (CONFIG.morningRandomInsideWindow) {
                let targetMs = Storage.getMorningTarget();
                if (!targetMs || targetMs < startMs || targetMs > endMs) {
                    targetMs = getRandomInt(startMs, endMs - 1);
                    Storage.setMorningTarget(targetMs);
                    console.log("[Stark HUD] 生成并保存早八时间:", new Date(targetMs).toLocaleTimeString());
                }
                if (now >= targetMs && now <= endMs) {
                    performMorningRequeue();
                }
            } else {
                if (now >= startMs && now <= endMs) {
                    performMorningRequeue();
                }
            }
        }

        updateMorningInfo();

        // 🆕 评论任务超时检测（防止任务卡死）
        if (Storage.isCommentInProgress() && Storage.isCommentTaskTimeout()) {
            console.log('[评论任务] ⚠️ 主循环检测到任务超时，执行自动重置');
            Storage.resetCommentTaskState();
            updateCommentTaskUI();
        }
        
        // 🆕 评论任务触发检测（参照早八机制）
        const commentWin = getCommentWindowMs();
        if (commentWin && !Storage.isCommentTaskDone() && !Storage.isCommentInProgress()) {
            const { startMs, endMs } = commentWin;
            if (CONFIG.commentTask.randomInsideWindow) {
                let targetMs = Storage.getCommentTarget();
                if (!targetMs || targetMs < startMs || targetMs > endMs) {
                    targetMs = getRandomInt(startMs, endMs - 1);
                    Storage.setCommentTarget(targetMs);
                    console.log("[评论任务] 生成并保存触发时间:", new Date(targetMs).toLocaleTimeString());
                }
                if (now >= targetMs && now <= endMs) {
                    performCommentTask();
                }
            } else {
                if (now >= startMs && now <= endMs) {
                    performCommentTask();
                }
            }
        }
        updateCommentTaskUI();

        if (scriptPaused) {
            updateUI("脚本已暂停（点击底部按钮恢复）", "--", "--", "gray");
            setTimeout(loop, 1000); return;
        }

        const enterBtn = findBtn(CONFIG.text.enter);
        const endBtn = findBtn(CONFIG.text.end);
        const queueBtn = findBtn(CONFIG.text.queuing);
        const skipHeavyQueueScan = queueBtn && state.standbyMode && (now - state.highRankLastHeavyScan < CONFIG.highRankDomScanInterval);
        const pageText = skipHeavyQueueScan ? '' : getRankContextText();

        if (!state.currentStuckLimit) state.currentStuckLimit = randomStuckLimitMs();
        let queueDurationDisplay = "--";
        if (state.qStart > 0) queueDurationDisplay = formatDurationMs(now - state.qStart);

        if (endBtn) {
            state.qStart = 0;
            state.standbyMode = false;

            if (!state.isOp) {
                state.isOp = true;
                state.sessStart = now;
                console.log("[Stark HUD] >>> 操作开始");
                const currentCount = Storage.get() + 1;
                PrismaXNotifier.notifyQueueSuccess(currentCount);
            }
            const durSec = Math.floor((now - state.sessStart) / 1000);
            updateUI(`正在操作 (${durSec}s)`, "已暂停", "--", "#00ff00");
            document.title = `>>> 操作中 ${durSec}s <<<`;
            state.lastMoveTime = now; state.clickRetryCount = 0;
        }
        else if (queueBtn) {
            if (state.isOp) {
                const sessionDuration = now - state.sessStart;
                state.isOp = false;

                if (sessionDuration < CONFIG.minSessionTime) {
                    console.log(`[Stark HUD] 检测到异常操作：时长 ${Math.floor(sessionDuration/1000)}s < ${CONFIG.minSessionTime/1000}s`);
                    Storage.addAnomaly();
                    updateAnomalyUI();

                    // 🆕 同步异常计数到 PrismaXController（确保连续异常触发生效）
                    if (window.PrismaXController) {
                        const prevCount = parseInt(localStorage.getItem('prismax_consecutive_anomalies') || '0', 10);
                        const newCount = prevCount + 1;
                        console.log(`[异常同步] 连续异常: ${prevCount} -> ${newCount}`);
                        
                        // 更新 localStorage 中的连续异常计数
                        try {
                            localStorage.setItem('prismax_consecutive_anomalies', String(newCount));
                        } catch (e) {}
                        
                        // 检查是否达到阈值
                        if (newCount >= window.PrismaXController.config.consecutiveAnomalyThreshold) {
                            console.log(`[异常同步] 🚨 连续异常达到 ${newCount} 次，触发自动退出！`);
                            window.PrismaXController.handleConsecutiveAnomalies();
                        }
                    }
                } else {
                    Storage.add();
                    const successCount = Storage.get();
                    const anomalyCount = Storage.getAnomalyCount();
                    PrismaXNotifier.notifyOperationComplete(successCount, anomalyCount);

                    // 🆕 成功操作时重置连续异常计数
                    try {
                        localStorage.setItem('prismax_consecutive_anomalies', '0');
                    } catch (e) {}
                }
            }

            if (maybeSwitchToArenaArm(queueBtn)) {
                setTimeout(loop, 1000);
                return;
            }

            if (!state.qStart) {
                state.qStart = now; state.lastRawRank = -1; state.rankWorseStreak = 0; state.blindCount = 0;
                state.lastMoveTime = now; state.currentStuckLimit = randomStuckLimitMs(); state.requeueUsed = false;
            }
            state.clickRetryCount = 0;

            if (skipHeavyQueueScan) {
                const cachedRank = state.lastRawRank !== -1 ? state.lastRawRank + 1 : "?";
                if (now - state.highRankLastUiUpdate >= CONFIG.highRankLoopInterval) {
                    updateUI(`静候模式: 排名 #${cachedRank}，低频扫描中...`, "省资源", queueDurationDisplay, "orange");
                    document.title = `Standby #${cachedRank}`;
                    state.highRankLastUiUpdate = now;
                }
                updateWatchdogHeartbeat();
                scheduleLoop(CONFIG.highRankLoopInterval);
                return;
            }
            state.highRankLastHeavyScan = now;

            const rawRank = parseRawRank(pageText);
            const timerStrFromPage = getActiveTimerString(pageText);
            const realRank = rawRank !== null ? rawRank + 1 : null;

            if (realRank !== null && realRank > CONFIG.highRankStandbyThreshold) {
                if (!state.standbyMode) {
                    console.log(`[Stark HUD] 进入静候模式：排名 #${realRank}`);
                    state.standbyMode = true;
                    state.highRankLastHeavyScan = now;
                    state.highRankLastUiUpdate = 0;
                }
                if (now - state.highRankLastUiUpdate >= CONFIG.highRankLoopInterval) {
                    updateUI(`静候模式: 排名 #${realRank}，等待捡漏...`, "低频扫描", queueDurationDisplay, "orange");
                    document.title = `Standby #${realRank}`;
                    state.highRankLastUiUpdate = now;
                }
                state.lastMoveTime = now;
                scheduleLoop(CONFIG.highRankLoopInterval);
                return;
            }

            if (state.standbyMode && realRank !== null && realRank <= CONFIG.highRankStandbyThreshold) {
                console.log(`[Stark HUD] 退出静候模式：排名回到 #${realRank}`);
                state.standbyMode = false;
                state.highRankLastUiUpdate = 0;
            }

            if (rawRank !== null) {
                state.blindCount = 0;

                if (state.morningRequeueActive) {
                    if (realRank > 100) {
                        if (!state.morningExtraRequeueDone) {
                            state.morningExtraRequeueDone = true;
                            updateUI(`早八: 排名 #${realRank} > 100，二次重排`, "--", queueDurationDisplay, "#66ccff");
                            leaveQueueThenReenter(queueBtn);
                            state.qStart = 0; state.lastRawRank = -1;
                            setTimeout(loop, 1000); return;
                        } else { state.morningRequeueActive = false; }
                    } else {
                        updateUI(`早八成功: 第 ${realRank} 名`, "--", queueDurationDisplay, "#00ff99");
                        state.morningRequeueActive = false;
                    }
                }

                if (state.lastRawRank !== -1 && rawRank > state.lastRawRank + CONFIG.rankDropTolerance) {
                    state.rankWorseStreak++;
                    if (state.rankWorseStreak >= 2) {
                        safeReload(`排名倒退: ${state.lastRawRank + 1} -> ${realRank}`);
                        return;
                    }
                } else {
                    state.rankWorseStreak = 0;
                }

                if (rawRank !== state.lastRawRank) {
                    state.lastRawRank = rawRank;
                    state.lastMoveTime = now;
                    state.currentStuckLimit = randomStuckLimitMs();
                }

                const stuckTime = now - state.lastMoveTime;
                const timeLeftStr = formatDurationMs(Math.max(0, state.currentStuckLimit - stuckTime));

                if (rawRank <= CONFIG.safeZoneRawLimit) {
                    updateUI(`决赛圈: 第 ${realRank} 名`, "坚守位置", queueDurationDisplay, "magenta");
                    state.lastMoveTime = now;
                } else {
                    const statusStr = timerStrFromPage ? `前车: ${timerStrFromPage} | 排名 #${realRank}` : `排队中: #${realRank}`;
                    const color = timerStrFromPage ? "#ffcc00" : "cyan";
                    updateUI(statusStr, `${timeLeftStr} (超时刷新)`, queueDurationDisplay, color);
                    if (stuckTime > state.currentStuckLimit) {
                        safeReload(`排名僵死 #${realRank}`);
                        return;
                    }
                }
                document.title = `Rank ${realRank}`;
            } else {
                state.blindCount++;
                if (state.morningRequeueActive) state.morningRequeueActive = false;
                const stuckTime = now - state.lastMoveTime;
                const timeLeftStr = formatDurationMs(Math.max(0, state.currentStuckLimit - stuckTime));
                const label = state.blindCount >= 3 ? "盲排中..." : "读取队列中...";
                updateUI(label, `${timeLeftStr} (超时刷新)`, queueDurationDisplay, "#aaaaaa");
                if (state.blindCount >= 3 && stuckTime > state.currentStuckLimit) {
                    safeReload("盲排超时");
                    return;
                }
            }

            const timerStr = getActiveTimerString(pageText);
            if (timerStr) {
                if (timerStr !== state.lastTimerStr) {
                    state.lastTimerStr = timerStr;
                    state.lastTimerChangeTime = now;
                }
                else if (now - state.lastTimerChangeTime > CONFIG.timerFreezeTimeout) {
                    safeReload("倒计时卡死检测");
                    return;
                }
            }
        }
        else if (enterBtn) {
            if (state.isOp) {
                const sessionDuration = now - state.sessStart;
                state.isOp = false;

                if (sessionDuration < CONFIG.minSessionTime) {
                    console.log(`[Stark HUD] 检测到异常操作：时长 ${Math.floor(sessionDuration/1000)}s < ${CONFIG.minSessionTime/1000}s`);
                    Storage.addAnomaly();
                    updateAnomalyUI();

                    // 🆕 同步异常计数到 PrismaXController
                    if (window.PrismaXController) {
                        const prevCount = parseInt(localStorage.getItem('prismax_consecutive_anomalies') || '0', 10);
                        const newCount = prevCount + 1;
                        console.log(`[异常同步] 连续异常: ${prevCount} -> ${newCount}`);
                        try {
                            localStorage.setItem('prismax_consecutive_anomalies', String(newCount));
                        } catch (e) {}
                        if (newCount >= window.PrismaXController.config.consecutiveAnomalyThreshold) {
                            console.log(`[异常同步] 🚨 连续异常达到 ${newCount} 次，触发自动退出！`);
                            window.PrismaXController.handleConsecutiveAnomalies();
                        }
                    }
                } else {
                    Storage.add();
                    const successCount = Storage.get();
                    const anomalyCount = Storage.getAnomalyCount();
                    PrismaXNotifier.notifyOperationComplete(successCount, anomalyCount);

                    // 🆕 成功操作时重置连续异常计数
                    try {
                        localStorage.setItem('prismax_consecutive_anomalies', '0');
                    } catch (e) {}
                }
            }

            if (maybeSwitchToArenaArm(null)) {
                setTimeout(loop, 1000);
                return;
            }

            state.qStart = 0;
            state.lastMoveTime = now;
            state.standbyMode = false;

            // 🆕 检查是否在冷却期内
            if (window.PrismaXController) {
                const controllerState = window.PrismaXController.getState();
                if (controllerState.anomalyCooldownUntil && now < controllerState.anomalyCooldownUntil) {
                    const remainingMs = controllerState.anomalyCooldownUntil - now;
                    const remainingMin = Math.ceil(remainingMs / 60000);
                    updateUI(`🔒 冷却期中：还剩 ${remainingMin} 分钟`, "--", "--", "orange");
                    console.log(`[冷却期] 还剩 ${remainingMin} 分钟，不自动进入队列`);
                    setTimeout(loop, 1000);
                    return;
                }
            }

            if (!enterBtn._pScheduled) {
                state.clickRetryCount++;
                const delay = getRandomInt(CONFIG.clickDelayMin, CONFIG.clickDelayMax);
                enterBtn._pScheduled = true;
                updateUI("发现目标信号", "--", "--", "yellow");
                setTimeout(() => {
                    try {
                        enterBtn.click();
                        updateWatchdogHeartbeat();
                    } catch (e) {
                        console.error(e);
                    } finally {
                        enterBtn._pScheduled = false;
                    }
                }, delay);
            }
        }
        else {
            updateUI("扫描信号中...", "--", "--", "#555555");
            if (now - state.lastMoveTime > CONFIG.fallbackReloadTimeout) {
                safeReload("无信号超时");
                return;
            }
        }

        setTimeout(loop, 1000);
    }

    function loop() {
        try {
            loopUnsafe();
        } catch (e) {
            recordScriptError('main.loop', e);
            setTimeout(loop, 1000);
        }
    }

    // 🆕 暴露评论任务测试函数到全局
    window.performCommentTask = performCommentTask;
    window.updateCommentTaskUI = updateCommentTaskUI;
    window.resetCommentTask = resetCommentTask;
    window.debugArenaArmSwitch = function() {
        const arena = findArmElement('Arena Arm', CONFIG.armSwitchTask.arenaArmXPath);
        const gold = findArmElement('Training Arm Gold', CONFIG.armSwitchTask.trainingGoldArmXPath);
        const avatar = getElementByXPath(CONFIG.armSwitchTask.robotAvatarXPath);
        const queueBtn = findBtn(CONFIG.text.queuing);
        const result = {
            avatarFound: !!avatar,
            avatarVisible: !!avatar && isVisibleElement(avatar),
            arenaFound: !!arena,
            arenaVisible: !!arena && isVisibleElement(arena),
            goldFound: !!gold,
            goldVisible: !!gold && isVisibleElement(gold),
            queueButtonFound: !!queueBtn,
            armSwitchDone: Storage.isArmSwitchDone(),
            armSwitchInProgress: Storage.isArmSwitchInProgress() || state.armSwitchInProgress
        };
        console.table(result);
        return result;
    };
    window.testSwitchToArenaArm = function() {
        Storage.setArmSwitchInProgress(false);
        localStorage.removeItem(STORAGE_KEYS.ARM_SWITCH_DONE);
        state.armSwitchInProgress = false;
        const queueBtn = findBtn(CONFIG.text.queuing);
        switchToArenaArm(queueBtn);
    };
    window.testReturnToTrainingGold = function() {
        Storage.setArmSwitchInProgress(false);
        state.armSwitchInProgress = false;
        const queueBtn = findBtn(CONFIG.text.queuing);
        returnToTrainingGold(queueBtn);
    };
    document.addEventListener('prismax:testSwitchToArenaArm', () => {
        window.testSwitchToArenaArm();
    });
    document.addEventListener('prismax:testReturnToTrainingGold', () => {
        window.testReturnToTrainingGold();
    });
    document.addEventListener('prismax:debugArenaArmSwitch', () => {
        window.debugArenaArmSwitch();
    });

    setTimeout(loop, 3000);
})();
