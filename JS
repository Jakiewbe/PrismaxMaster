        localStorage.setItem(MORNING_PRERELOAD_KEY, getTodayStr());
    }

    function parseTimeToday(hm) {
        if (!hm || typeof hm !== 'string') return null;
        const parts = hm.split(':');
        if (parts.length < 2) return null;
        const h = Number(parts[0]); const m = Number(parts[1]);
        if (isNaN(h) || isNaN(m)) return null;
        const now = new Date();
        return new Date(now.getFullYear(), now.getMonth(), now.getDate(), h, m, 0, 0);
    }

    function getMorningWindowMs() {
        if (!CONFIG.morningEnabled) return null;
        const start = parseTimeToday(CONFIG.morningWindowStart);
        const end = parseTimeToday(CONFIG.morningWindowEnd);
        if (!start || !end) return null;
        const startMs = start.getTime(); const endMs = end.getTime();
        if (!(endMs > startMs)) return null;
        return { startMs, endMs };
    }

    function getRankContextText() {
        const panels = Array.from(document.querySelectorAll('div'));
        const queuePanel = panels.find(el => {
            const txt = el.innerText || "";
            return txt.includes("You are now in the queue.") && txt.includes("users in front of you");
        });
        if (queuePanel) return queuePanel.innerText;
        return document.body.innerText || "";
    }

    function parseRawRank(text) {
        if (!text) return null;
        let m = text.match(/(?:Position|Queue|Rank)\D*(\d{1,4})/i) || text.match(/(\d{1,4})\s*in\s*queue/i);
        if (m) return parseInt(m[1], 10);
        const m2 = text.match(/There'?s\s+(\d{1,4})\s+users?\s+in\s+front\s+of\s+you/i);
        if (m2) return parseInt(m2[1], 10);
        return null;
    }

    function getActiveTimerString(text) {
        if (!text) return null;
        const m = text.match(/Active:\s*(\d{1,2}:\d{2})/i);
        return m ? m[1] : null;
    }

    function findBtn(keywords) {
        const candidates = Array.from(document.querySelectorAll('button, div[role="button"], span'));
        return candidates.find(el => {
            if (!el.offsetParent) return false;
            if (el.tagName === 'A' || el.closest('a')) return false;
            const txt = el.innerText.trim();
            if (!txt) return false;
            if (CONFIG.text.blacklist.some(bad => txt.includes(bad))) return false;
            const lower = txt.toLowerCase();
            const isMatch = keywords.some(k => lower.includes(k.toLowerCase()));
            if (isMatch && keywords === CONFIG.text.enter && lower.includes("leave")) return false;
            return isMatch;
        });
    }

    function isVisibleElement(el) {
        if (!el) return false;
        const style = window.getComputedStyle(el);
        if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') return false;
        const rect = el.getBoundingClientRect();
        return rect.width > 0 && rect.height > 0;
    }

    function findExactVisibleButton(labels) {
        const normalized = labels.map(label => label.toLowerCase());
        const candidates = Array.from(document.querySelectorAll('button, div[role="button"]'));
        return candidates.find(el => {
            if (!isVisibleElement(el)) return false;
            const text = (el.innerText || el.textContent || '').trim().toLowerCase();
            return normalized.includes(text);
        });
    }

    function confirmLeaveQueueIfPresent() {
        let confirmBtn = document.querySelector('button[class*="leaveModalConfirmBtn"], .QueuePanel_leaveModalConfirmBtn__ZtiIr');
        if (confirmBtn && !isVisibleElement(confirmBtn)) confirmBtn = null;
        if (!confirmBtn) confirmBtn = findExactVisibleButton(['Leave queue', 'Leave Queue']);
        if (!confirmBtn) return false;
        try {
            confirmBtn.click();
            console.log('[Stark HUD] 已确认离开队列弹窗');
            return true;
        } catch (e) {
            console.error('[Stark HUD] 点击 Leave queue 确认失败:', e);
            return false;
        }
    }

    function hasLeaveQueueModal() {
        const confirmBtn = document.querySelector('button[class*="leaveModalConfirmBtn"], .QueuePanel_leaveModalConfirmBtn__ZtiIr');
        if (confirmBtn && isVisibleElement(confirmBtn)) return true;
        return !!findExactVisibleButton(['Leave queue', 'Leave Queue']);
    }

    function waitUntilQueueLeft(done, attempt = 0) {
        const modalStillOpen = hasLeaveQueueModal();
        const enterBtn = findBtn(CONFIG.text.enter);
        const queueBtn = findBtn(CONFIG.text.queuing);

        if (!modalStillOpen && (enterBtn || !queueBtn)) {
            console.log('[Stark HUD] 已退出当前队列，可以切换手臂');
            done(true);
            return;
        }

        if (attempt >= 30) {
            console.log('[Stark HUD] 等待退出队列超时');
            done(false);
            return;
        }

        setTimeout(() => waitUntilQueueLeft(done, attempt + 1), 500);
    }

    function confirmLeaveAndWait(done, attempt = 0) {
        if (confirmLeaveQueueIfPresent()) {
            setTimeout(() => waitUntilQueueLeft(done), 500);
            return;
        }
        if (attempt >= 12) {
            console.log('[Stark HUD] 未检测到离队确认弹窗，继续等待退出状态');
            waitUntilQueueLeft(done);
            return;
        }
        setTimeout(() => confirmLeaveAndWait(done, attempt + 1), 250);
    }

    function clickEnterAfterLeave() {
