            console.log('[评论任务] 输入框搜索结果:', input);
            
            if (!input) {
                console.error('[评论任务] ❌ 未找到输入框');
                if (retryCount < maxRetries) {
                    console.log(`[评论任务] 重试 ${retryCount + 1}/${maxRetries}...`);
                    await new Promise(r => setTimeout(r, retryDelay));
                    return sendOneComment(comment, retryCount + 1);
                }
                return false;
            }

            // 输入评论（React 兼容方式）
            input.focus();
            
            // 🆕 使用 React 兼容的方式设置值
            // 获取原生的 value setter
            const nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
            nativeInputValueSetter.call(input, comment);
            
            // 触发 React 的 onChange 事件
            const inputEvent = new Event('input', { bubbles: true });
            input.dispatchEvent(inputEvent);
            
            console.log(`[评论任务] 📝 已输入内容: "${comment.substring(0, 30)}..."`);

            // 等待输入完成（2秒）
            await new Promise(r => setTimeout(r, 2000));

            // 🆕 点击发送按钮
            console.log(`[评论任务] 🖱️ 查找并点击发送按钮...`);
            
            // 查找发送按钮（尝试多种选择器）
            let sendBtn = document.querySelector('button[class*="LiveChatModule_sendButton"]');
            if (!sendBtn) {
                sendBtn = document.querySelector('button[type="submit"]');
            }
            if (!sendBtn) {
                // 查找输入框旁边的按钮
                const inputParent = input.closest('div, form');
                if (inputParent) {
                    sendBtn = inputParent.querySelector('button');
                }
            }
            if (!sendBtn) {
                // 查找包含 send 图标的按钮
                const allBtns = document.querySelectorAll('button');
                sendBtn = Array.from(allBtns).find(btn => {
                    const svg = btn.querySelector('svg');
                    return svg && btn.offsetParent;
                });
            }
            
            console.log(`[评论任务] 发送按钮:`, sendBtn);
            
            if (sendBtn) {
                // 确保按钮获得焦点后再点击
                sendBtn.focus();
                await new Promise(r => setTimeout(r, 100));
                sendBtn.click();
                console.log(`[评论任务] ✅ 已点击发送按钮`);
            } else {
                // 备用：尝试 Enter 键
                console.log(`[评论任务] ⚠️ 未找到发送按钮，尝试 Enter 键...`);
                input.dispatchEvent(new KeyboardEvent('keydown', { 
                    key: 'Enter', keyCode: 13, bubbles: true 
                }));
            }
            
            // 等待消息发送完成（2秒）
            await new Promise(r => setTimeout(r, 2000));
            
            console.log(`[评论任务] ✅ 已发送: "${comment.substring(0, 30)}..."`);
            return true;
        } catch (e) {
            console.error('[评论任务] 发送错误:', e);
            if (retryCount < maxRetries) {
                console.log(`[评论任务] 重试 ${retryCount + 1}/${maxRetries}...`);
                await new Promise(r => setTimeout(r, retryDelay));
                return sendOneComment(comment, retryCount + 1);
            }
            return false;
        }
    }

    // 🆕 重置评论任务状态（用于测试/手动重置）
    function resetCommentTask() {
        localStorage.removeItem(STORAGE_KEYS.COMMENT_TASK_DONE);
        localStorage.removeItem(STORAGE_KEYS.COMMENT_TASK_TARGET);
        Storage.resetCommentTaskState();  // 使用新的重置方法（同时清理开始时间）
        console.log('[评论任务] ✅ 已重置评论任务状态（包括超时相关）');
        updateCommentTaskUI();
    }

    // 🆕 执行评论任务主函数（增强版：超时保护 + 完善错误处理）
    async function performCommentTask() {
        console.log('[评论任务] 检查状态:', {
            isDone: Storage.isCommentTaskDone(),
            inProgress: Storage.isCommentInProgress(),
            startTime: Storage.getCommentTaskStartTime()
        });
        
        if (Storage.isCommentTaskDone()) {
            console.log('[评论任务] ⚠️ 今日任务已完成，跳过');
            return;
        }
        
        if (Storage.isCommentInProgress()) {
            // 🆕 检查是否超时（5分钟）
            if (Storage.isCommentTaskTimeout()) {
                console.log('[评论任务] ⚠️ 检测到任务超时，自动重置状态');
                Storage.resetCommentTaskState();
                // 重置后继续执行
            } else {
                console.log('[评论任务] ⚠️ 任务正在进行中，跳过');
                return;
            }
        }

        console.log('[评论任务] === 开始执行评论任务 ===');
        console.log('[评论任务] 开始时间:', new Date().toLocaleString());
        Storage.setCommentInProgress(true);  // 同时会记录开始时间
        updateCommentTaskUI();

        // 🆕 使用 finally 确保状态一定会被重置
        let taskSuccess = false;
        let successCount = 0;
        
        try {
            // Step 1: 点击 Live Chat 标签（使用多种方法尝试）
            let liveChatBtn = null;
            
            // 方法0: 使用实际的 CSS 类名选择器（最可靠）
            try {
                const tabButtons = document.querySelectorAll('button[class*="TeleOpRightPanel_tab"]');
                liveChatBtn = Array.from(tabButtons).find(el => (el.innerText || '').trim() === 'Live Chat');
                console.log('[评论任务] 方法0 (CSS类名) 结果:', liveChatBtn ? '找到' : '未找到');
            } catch (e) {
                console.log('[评论任务] 方法0 出错:', e.message);
            }
            
            // 方法1: 精确匹配 "Live Chat" 文字
            if (!liveChatBtn) {
                try {
                    const allElements = Array.from(document.querySelectorAll('button, span, div'));
                    liveChatBtn = allElements.find(el => {
                        const txt = (el.innerText || el.textContent || '').trim();
                        return txt === 'Live Chat';
                    });
                    console.log('[评论任务] 方法1 (精确匹配) 结果:', liveChatBtn ? '找到' : '未找到');
                } catch (e) {
                    console.log('[评论任务] 方法1 出错:', e.message);
                }
            }
            
            // 方法2: 查找 Queue 旁边的元素
            if (!liveChatBtn) {
                try {
                    const queueEl = Array.from(document.querySelectorAll('button')).find(el => (el.innerText || '').trim() === 'Queue');
                    if (queueEl && queueEl.parentElement) {
                        const siblings = Array.from(queueEl.parentElement.children);
                        liveChatBtn = siblings.find(el => (el.innerText || '').trim().includes('Live Chat'));
                        console.log('[评论任务] 方法2 (Queue旁边) 结果:', liveChatBtn ? '找到' : '未找到');
                    }
                } catch (e) {
                    console.log('[评论任务] 方法2 出错:', e.message);
                }
            }
            
            // 方法3: 使用 findTabBtn
            if (!liveChatBtn) {
                try {
                    liveChatBtn = findTabBtn(CONFIG.text.liveChat);
                    console.log('[评论任务] 方法3 (findTabBtn) 结果:', liveChatBtn ? '找到' : '未找到');
                } catch (e) {
                    console.log('[评论任务] 方法3 出错:', e.message);
                }
            }
            
            console.log('[评论任务] Live Chat 按钮最终结果:', liveChatBtn ? '✅ 找到' : '❌ 未找到');
            
            if (!liveChatBtn) {
                console.error('[评论任务] ❌ 未找到 Live Chat 按钮，任务终止');
                return;  // finally 会处理状态重置
            }
            
            liveChatBtn.click();
            console.log('[评论任务] ✅ 已点击 Live Chat');

            // 等待界面加载
            await new Promise(r => setTimeout(r, 2000));

            // Step 2: 发送评论
            const commentCount = getRandomInt(CONFIG.commentTask.commentCount.min, CONFIG.commentTask.commentCount.max);
            const comments = CONFIG.commentTask.comments;
            const usedIndices = [];

            for (let i = 0; i < commentCount; i++) {
                try {
                    // 随机选择一条未使用的评论
                    let idx;
                    do {
                        idx = getRandomInt(0, comments.length - 1);
                    } while (usedIndices.includes(idx) && usedIndices.length < comments.length);
                    usedIndices.push(idx);

                    const comment = comments[idx];
                    const success = await sendOneComment(comment);
                    if (success) successCount++;
                    
                    console.log(`[评论任务] 进度: ${i + 1}/${commentCount}，成功: ${successCount}`);

                    // 评论间隔
                    if (i < commentCount - 1) {
                        const delay = getRandomInt(CONFIG.commentTask.commentDelay.min, CONFIG.commentTask.commentDelay.max);
                        console.log(`[评论任务] 等待 ${delay}ms 后发送下一条...`);
                        await new Promise(r => setTimeout(r, delay));
                    }
                } catch (commentError) {
                    console.error(`[评论任务] 第 ${i + 1} 条评论发送失败:`, commentError.message);
                    // 继续尝试下一条
                }
            }

            console.log(`[评论任务] ✅ 已发送 ${successCount}/${commentCount} 条评论`);

            // Step 3: 返回 Queue（使用同样的方法）
            await new Promise(r => setTimeout(r, 1000));
            
            try {
                // 🆕 先检查界面是否收起来了，如果收起来就重新展开
                let openBtn = document.querySelector('button[class*="TeleOpRightPanel_openBtnDesktop"]');
                if (openBtn) {
                    console.log('[评论任务] 界面已收起，点击展开...');
                    openBtn.click();
                    await new Promise(r => setTimeout(r, 1500));
                }
                
                // 使用 CSS 类名选择器找 Queue 按钮
                let queueBtn = Array.from(document.querySelectorAll('button[class*="TeleOpRightPanel_tab"]'))
                    .find(el => (el.innerText || '').trim() === 'Queue');
                
                if (!queueBtn) {
                    queueBtn = findTabBtn(CONFIG.text.queue);
                }
                
                if (queueBtn) {
                    queueBtn.click();
                    console.log('[评论任务] ✅ 已返回 Queue');
                } else {
                    console.log('[评论任务] ⚠️ 未找到 Queue 按钮（不影响任务完成）');
                }
            } catch (queueError) {
                console.log('[评论任务] ⚠️ 返回 Queue 失败:', queueError.message);
                // 不影响任务标记为完成
            }

            // 标记任务成功
            taskSuccess = true;

        } catch (e) {
            console.error('[评论任务] ❌ 执行错误:', e);
            console.error('[评论任务] 错误堆栈:', e.stack);
        } finally {
            // 🆕 确保状态一定会被正确处理
            console.log('[评论任务] finally 块执行，taskSuccess:', taskSuccess, 'successCount:', successCount);
            
            if (taskSuccess || successCount > 0) {
                // 任务成功或至少发送了一条评论，标记为完成
                Storage.markCommentTaskDone();
                Storage.setCommentInProgress(false);
                
                // 🆕 记录评论任务完成日志
                if (window.PrismaXController && window.PrismaXController.queueEventLog) {
                    window.PrismaXController.queueEventLog('comment_task_complete', {
                        successCount: successCount,
                        timestamp: Date.now()
                    });
                }
                
                if (successCount > 0) {
                    PrismaXNotifier.notifyCommentTaskComplete(successCount);
                }
                console.log('[评论任务] === 评论任务完成 ===');
            } else {
                // 任务失败，重置状态以便稍后重试
                Storage.setCommentInProgress(false);
                
                // 🆕 记录评论任务失败日志
                if (window.PrismaXController && window.PrismaXController.queueEventLog) {
                    window.PrismaXController.queueEventLog('comment_task_failed', {
                        reason: 'no_success_comments',
                        timestamp: Date.now()
                    });
                }
                console.log('[评论任务] === 评论任务失败，状态已重置，稍后可重试 ===');
            }
            
            updateCommentTaskUI();
        }
    }

    function hasMorningDoneToday() {
        if (CONFIG.morningIgnoreDone) return false;
        return localStorage.getItem(MORNING_DONE_KEY) === getTodayStr();
    }

    function markMorningDoneToday() {
        console.log("[Stark HUD] 标记今日早八已完成");
