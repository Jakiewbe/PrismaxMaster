{
  "manifest_version": 3,
  "name": "PrismaX Assistant",
  "version": "3.1.0",
  "description": "PrismaX cross-platform automation bridge with notifications, state control, and performance optimization.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://app.prismax.ai/*",
    "https://api2.pushdeer.com/*",
    "https://sctapi.ftqq.com/*",
    "https://api.telegram.org/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.prismax.ai/*"],
      "js": [
        "content/utils.js",
        "content/config.js",
        "content/storage.js",
        "content/notifier.js",
        "content/controller.js",
        "content/panel.js",
        "content/morning.js",
        "content/comment-task.js",
        "content/arm-switch.js",
        "content/automation.js",
        "content/content-script.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PrismaX Assistant"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "minimum_chrome_version": "111"
}
